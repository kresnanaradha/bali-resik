PORT=8080
DB_DSN=root:@tcp(127.0.0.1:3306)/bali_resik?charset=utf8mb4&parseTime=True&loc=Local
ALLOWED_ORIGIN=http://localhost:5173

# AUTH_MODE=dev auto-provisions a local admin user and skips real Firebase
# token verification, so the API is testable without a Firebase project.
# Switch to AUTH_MODE=firebase (+ set FIREBASE_PROJECT_ID) for production.
# Independent of AUTH_MODE: /auth/register and /auth/login issue the app's
# own JWT (checked against users.password_hash), and a valid one of those is
# always honored first regardless of AUTH_MODE.
AUTH_MODE=dev
FIREBASE_PROJECT_ID=

# Signs the app's own login tokens. Change this to a long random value for
# any real deployment — anyone with this secret can mint valid admin tokens.
JWT_SECRET=dev-insecure-secret-change-me
